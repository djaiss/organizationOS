{
  "app/*.php": {
    "alternate": ["tests/Unit/{}Test.php", "tests/Feature/{}Test.php"]
  },
  "tests/Feature/*Test.php": {
    "alternate": "app/{}.php"
  },
  "tests/Feature/Api/*Test.php": {
    "alternate": "app/Http/Controllers/Api/{}.php"
  },
  "tests/Unit/*Test.php": {
    "alternate": "app/{}.php"
  }
}
